# API Service Configuration
SERVICE_NAME=api
SERVICE_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=local

# Database
DATABASE_URL=postgresql://postgres:pwaisensor@postgres:5432/postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Authentication (OAuth2 client_credentials — service-to-service)
# Login service URL for token acquisition and JWKS verification
LOGIN_SERVICE_URL=http://login:8005
# Service identity — must match what login registers on startup
SERVICE_CLIENT_ID=api-service
SERVICE_CLIENT_SECRET=changeme
# Fallback bootstrap secret (fetches client_secret from login if SECRET is empty)
INTERNAL_API_SECRET=changeme

# Backend Services URLs (internal container network)
STOCK_SERVICE_URL=http://stock:8000
RETAIL_SERVICE_URL=http://retail:8000
IOT_SERVICE_URL=http://iot:8000

# CORS Configuration
CORS_ORIGINS=https://localhost,http://localhost,http://localhost:3000,http://localhost:9302

# WebSocket Configuration (API aggregator)
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10
WS_OPEN_TIMEOUT=10
WS_CLEANUP_GRACE_SECONDS=30
WS_RECONNECT_BASE_DELAY=2.0
WS_RECONNECT_MAX_DELAY=30.0
WS_INITIAL_DATA_CACHE_TTL=30
WS_MAX_CLIENTS_PER_POOL=500
WS_SEND_TIMEOUT=5.0

# Admin Credentials (DEPRECATED — services now use client_credentials grant)
# Only needed if legacy password-grant code is still in use.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# Telemetry
ENABLE_TELEMETRY_EXPORT=false
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-token
INFLUXDB_ORG=paperweight.ai
